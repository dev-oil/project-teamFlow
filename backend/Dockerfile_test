# 1단계: 빌드 단계
FROM node:20-alpine AS build

WORKDIR /app

# package.json과 package-lock.json 복사
COPY package*.json ./

# 개발용 의존성 포함 설치
RUN npm ci

# 소스 코드 복사
COPY . .

# TypeScript 빌드
RUN npm run build


# 2단계: 운영 단계 (더 작은 이미지)
FROM node:20-alpine

WORKDIR /app

# 운영에 필요한 의존성만 설치
COPY package*.json ./
RUN npm ci --only=production

# 빌드된 JS 파일만 복사
COPY --from=build /app/dist ./dist

# 환경 변수
ENV PORT=3000
EXPOSE 3000

# 앱 실행
CMD ["npm", "start"]
