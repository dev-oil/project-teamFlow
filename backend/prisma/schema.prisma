generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model boxes {
  id            Int        @id @default(autoincrement())
  workspaces_id Int
  order         Int
  title         String     @db.VarChar(200)
  created_at    DateTime   @default(now()) @db.Timestamp(0)
  updated_at    DateTime   @default(now()) @db.Timestamp(0)
  workspaces    workspaces @relation(fields: [workspaces_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_boxes_workspaces1")
  cards         cards[]

  @@index([workspaces_id], map: "fk_boxes_workspaces1_idx")
}

model cards {
  id          Int      @id @default(autoincrement())
  boxes_id    Int
  order       Int
  pinned      Int      @default(0) @db.TinyInt
  title       String   @db.VarChar(100)
  color       String?  @db.VarChar(20)
  description String?  @db.Text
  start_date  DateTime @db.Date
  end_date    DateTime @db.Date
  assignee    Json?
  file        Json?
  created_at  DateTime @default(now()) @db.Timestamp(0)
  updated_at  DateTime @default(now()) @db.Timestamp(0)
  boxes       boxes    @relation(fields: [boxes_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_cards_boxes1")

  @@index([boxes_id], map: "fk_cards_boxes1_idx")
}

model meeting_notes {
  id                                  Int      @id @default(autoincrement())
  users_id                            Int
  title                               String   @db.VarChar(100)
  created_at                          DateTime @default(now()) @db.Timestamp(0)
  participant                         Json
  content                             String?  @db.Text
  file                                Json?
  updated_at                          DateTime @default(now()) @db.Timestamp(0)
  users_meeting_notes_users_idTousers users    @relation("meeting_notes_users_idTousers", fields: [users_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_meeting_notes_users1")

  @@index([users_id], map: "fk_meeting_notes_users1_idx")
}

model members {
  id            Int          @id @default(autoincrement())
  users_id      Int
  workspaces_id Int
  role          members_role
  users         users        @relation(fields: [users_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_members_users")
  workspaces    workspaces   @relation(fields: [workspaces_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_members_workspaces1")

  @@index([users_id], map: "fk_members_users_idx")
  @@index([workspaces_id], map: "fk_members_workspaces1_idx")
}

model users {
  id                                          Int             @id @default(autoincrement())
  email                                       String          @unique(map: "email_UNIQUE") @db.VarChar(100)
  password                                    String          @db.VarChar(255)
  name                                        String          @db.VarChar(100)
  phone                                       String          @db.VarChar(11)
  profile_image                               String?         @db.VarChar(255)
  created_at                                  DateTime        @default(now()) @db.Timestamp(0)
  updated_at                                  DateTime        @default(now()) @db.Timestamp(0)
  is_verified                                 Int             @default(0) @db.TinyInt
  invitations                                 invitations[]
  meeting_notes_meeting_notes_users_idTousers meeting_notes[] @relation("meeting_notes_users_idTousers")
  members                                     members[]
  workspaces                                  workspaces[]
}

model workspaces {
  id          Int           @id @default(autoincrement())
  users_id    Int
  name        String        @db.VarChar(100)
  created_at  DateTime      @default(now()) @db.Timestamp(0)
  updated_at  DateTime      @default(now()) @db.Timestamp(0)
  boxes       boxes[]
  invitations invitations[]
  members     members[]
  users       users         @relation(fields: [users_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_workspaces_users1")

  @@index([users_id], map: "fk_workspaces_users1_idx")
}

model invitations {
  id            Int        @id @default(autoincrement())
  workspaces_id Int
  email         String     @unique(map: "email_UNIQUE") @db.VarChar(100)
  token         String     @unique(map: "token_UNIQUE") @db.VarChar(64)
  expires_at    DateTime   @db.DateTime(0)
  used          Int        @default(0) @db.TinyInt
  created_at    DateTime   @default(now()) @db.Timestamp(0)
  users_id      Int
  users         users      @relation(fields: [users_id], references: [id], onUpdate: Restrict, map: "fk_invitations_users1")
  workspaces    workspaces @relation(fields: [workspaces_id], references: [id], onDelete: NoAction, onUpdate: NoAction, map: "fk_invitations_workspaces1")

  @@index([workspaces_id], map: "fk_invitations_workspaces1_idx")
  @@index([users_id], map: "fk_invitations_users1_idx")
}

enum members_role {
  host
  guest
}
