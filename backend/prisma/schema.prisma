generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mysql"
  url      = env("DATABASE_URL")
}

model boxes {
  id            Int    @id
  workspaces_id Int
  order         Int
  title         String @db.VarChar(200)

  @@index([workspaces_id], map: "fk_boxes_workspaces1_idx")
}

model cards {
  id          Int      @id
  boxes_id    Int
  order       Int
  title       String   @db.VarChar(100)
  color       String?  @db.VarChar(20)
  description String?  @db.Text
  start_date  DateTime @db.Date
  end_date    DateTime @db.Date
  assignee    Json?
  file        Json?
  created_at  DateTime @default(now()) @db.Timestamp(0)

  @@index([boxes_id], map: "fk_cards_boxes1_idx")
}

model meeting_notes {
  id            Int       @id
  users_id      Int
  lates_user_id Int?
  title         String    @db.VarChar(200)
  created_at    DateTime  @default(now()) @db.Timestamp(0)
  latest_at     DateTime? @db.Timestamp(0)
  content       String?   @db.Text
  file          Json?

  @@index([users_id], map: "fk_meeting_notes_users1_idx")
  @@index([lates_user_id], map: "fk_meeting_notes_users2_idx")
}

/// This model or at least one of its fields has comments in the database, and requires an additional setup for migrations: Read more: https://pris.ly/d/database-comments
model members {
  id            Int          @id @default(autoincrement())
  users_id      Int
  workspaces_id Int
  role          members_role

  @@index([users_id], map: "fk_members_users_idx")
  @@index([workspaces_id], map: "fk_members_workspaces1_idx")
}

model users {
  id            Int      @id @default(autoincrement())
  email         String   @db.VarChar(100)
  password      String   @db.VarChar(255)
  name          String   @db.VarChar(100)
  phone         String   @db.VarChar(11)
  profile_image String?  @db.VarChar(255)
  created_at    DateTime @default(now()) @db.Timestamp(0)
  updated_at    DateTime @default(now()) @db.Timestamp(0)
}

model workspaces {
  id         Int      @id @default(autoincrement())
  name       String   @db.VarChar(100)
  created_at DateTime @default(now()) @db.Timestamp(0)
  users_id   Int

  @@index([users_id], map: "fk_workspaces_users1_idx")
}

enum members_role {
  host
  guest
}
